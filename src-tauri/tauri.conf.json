{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Quantum Download Manager",
  "version": "1.0.3",
  "identifier": "com.parveenbhadoo.qdm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quantum Download Manager",
        "width": 1200,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": "#0f0f13",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/yt-dlp.exe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Parveen Bhadoo",
    "category": "Utility",
    "shortDescription": "Fast multi-segment download manager",
    "longDescription": "Quantum Download Manager — a fast, cross-platform download manager with multi-segment acceleration, browser integration, and system tray support.",
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "",
      "wix": {},
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": null,
      "hardenedRuntime": false
    }
  }
}

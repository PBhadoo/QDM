{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for QDM",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "notification:default",
    "notification:allow-notify",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
